rl.question('Digite o primeiro valor: ', (resposta) => {
  inicio = Number(resposta);

  rl.question('Digite o último valor: ', (resposta) => {
    fim = Number(resposta);

    rl.question('Digite o incremento: ', (resposta) => {
      incremento = Number(resposta);

      console.log('Contagem:');

      for (let i = inicio; i < fim; i += incremento) {
        process.stdout.write(i + ' ');
      }

      console.log('\nAcabou!');
      rl.close();
    }); 
});
});

